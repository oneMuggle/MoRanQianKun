{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsc/tsconfig.core.tsbuildinfo",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true
  },
  "include": [
    "src/models/character.ts",
    "src/models/environment.ts",
    "src/models/battle.ts",
    "src/models/item.ts",
    "src/models/kungfu.ts",
    "src/models/sect.ts",
    "src/models/task.ts",
    "src/models/imageGeneration.ts",
    "src/models/worldbook.ts",
    "src/models/world.ts",
    "src/models/story.ts",
    "src/models/relationship.ts",
    "src/models/eventTrigger.ts",
    "src/models/narrativeGrammar.ts",
    "src/models/api-config.ts",
    "src/models/appRegistry.ts",
    "src/models/theme-visual.ts",
    "src/models/storyPlan.ts",
    "src/models/heroinePlan.ts",
    "src/models/novelDecomposition.ts",
    "src/models/novelWriting.ts",
    "src/models/installedApps.ts",
    "src/models/nsfwApps.ts",
    "src/models/eraTheme.ts",
    "src/models/eraAssets.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src/models/contemporary/**",
    "src/models/contpective/**",
    "src/models/npcNSFWEnhancement/**",
    "src/models/nsfwCore/**",
    "src/models/photographyNSFW/**",
    "src/models/era-config/**",
    "src/models/eraTheme/**",
    "src/models/avg/**",
    "src/models/bdsmNSFW/**",
    "src/models/boardGameNSFW/**",
    "src/models/campusNSFW/**",
    "src/models/dailyTown/**",
    "src/models/era-device/**",
    "src/models/exploration/**",
    "src/models/exposureNSFW/**",
    "src/models/outdoorNSFW/**",
    "src/models/property/**",
    "src/models/urbanDriverNSFW/**",
    "src/models/domain/**",
    "src/models/game/**",
    "src/models/planning/**",
    "src/models/fandomPlanning/**",
    "src/models/system/**"
  ]
}
