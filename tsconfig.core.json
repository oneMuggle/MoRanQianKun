{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "node_modules/.cache/tsc/tsconfig.core.tsbuildinfo",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "useUnknownInCatchVariables": true
  },
  "include": [
    "models/character.ts",
    "models/environment.ts",
    "models/battle.ts",
    "models/item.ts",
    "models/kungfu.ts",
    "models/sect.ts",
    "models/task.ts",
    "models/imageGeneration.ts",
    "models/worldbook.ts",
    "models/world.ts",
    "models/story.ts",
    "models/relationship.ts",
    "models/eventTrigger.ts",
    "models/narrativeGrammar.ts",
    "models/api-config.ts",
    "models/appRegistry.ts",
    "models/theme-visual.ts",
    "models/storyPlan.ts",
    "models/heroinePlan.ts",
    "models/novelDecomposition.ts",
    "models/novelWriting.ts",
    "models/installedApps.ts",
    "models/nsfwApps.ts",
    "models/eraTheme.ts",
    "models/eraAssets.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "models/contemporary/**",
    "models/contpective/**",
    "models/npcNSFWEnhancement/**",
    "models/nsfwCore/**",
    "models/photographyNSFW/**",
    "models/era-config/**",
    "models/eraTheme/**",
    "models/avg/**",
    "models/bdsmNSFW/**",
    "models/boardGameNSFW/**",
    "models/campusNSFW/**",
    "models/dailyTown/**",
    "models/era-device/**",
    "models/exploration/**",
    "models/exposureNSFW/**",
    "models/outdoorNSFW/**",
    "models/property/**",
    "models/urbanDriverNSFW/**",
    "models/domain/**",
    "models/game/**",
    "models/planning/**",
    "models/fandomPlanning/**",
    "models/system/**"
  ]
}
