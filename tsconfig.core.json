{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true
  },
  "include": [
    "models/**/*.ts",
    "models/**/*.tsx",
    "services/dbService.ts",
    "services/ai/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
