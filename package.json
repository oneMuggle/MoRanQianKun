{
  "name": "墨染乾坤---万象纪元",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:cov": "vitest run --coverage",
    "stress:test": "node scripts/promptStressTest.js",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "lint:graph": "madge --circular --extensions ts,tsx --warning .",
    "lint:dead": "ts-prune",
    "lint:unused": "knip",
    "metrics:baseline": "node scripts/collectMetricsBaseline.mjs",
    "size": "size-limit"
  },
  "size-limit": [
    { "name": "entry",       "path": "dist/assets/index-*.js",        "limit": "350 KB" },
    { "name": "vendor",      "path": "dist/assets/vendor-*.js",       "limit": "3.7 MB" },
    { "name": "game-runtime","path": "dist/assets/game-runtime-*.js", "limit": "3.0 MB" }
  ],
  "dependencies": {
    "@capacitor/android": "^7.4.5",
    "@capacitor/cli": "^7.4.5",
    "@capacitor/core": "^7.4.5",
    "fflate": "^0.8.2",
    "js-tiktoken": "^1.0.21",
    "node": "^25.6.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-app": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "ast-grep": "^0.1.0",
    "autoprefixer": "^10.4.27",
    "depcheck": "^1.4.7",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "jsdom": "^29.1.0",
    "knip": "^6.15.0",
    "madge": "^8.0.0",
    "postcss": "^8.5.8",
    "size-limit": "^12.1.0",
    "tailwindcss": "^3.4.19",
    "ts-prune": "^0.10.3",
    "tslib": "^2.8.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.5"
  }
}
